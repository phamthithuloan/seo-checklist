# Backend environment configuration
# Copy to .env and adjust as needed.

ENVIRONMENT=development

# Database — async URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://seo:seo@localhost:5432/seo_checklist

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Anthropic API key for AI proofread (optional, paid)
# Leave empty to disable AI grammar / spelling check.
ANTHROPIC_API_KEY=

# Google Gemini API key — powers the fact-check in "Tin cậy & Kiểm chứng AI".
# FREE: get one at https://aistudio.google.com/apikey (no credit card).
# Leave empty: 3 heuristic checks still run free; only fact-check is skipped.
GEMINI_API_KEY=
# gemini-2.5-flash: free tier ~5 req/phút (đủ cho dùng bình thường, có Google
# Search grounding). Lưu ý gemini-2.0-flash thường KHÔNG có quota free (limit 0).
GEMINI_MODEL=gemini-2.5-flash
